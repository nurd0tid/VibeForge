# Local services. Keep both bound to loopback; this app can execute local commands.
VK_WEB_HOST=127.0.0.1
VK_WEB_PORT=3456
# Optional bind host for Next.js. Leave empty to use VK_WEB_HOST.
# Use 127.0.0.1 when your custom domain maps to loopback in hosts.
VK_WEB_BIND_HOST=
VK_ORCHESTRATOR_HOST=127.0.0.1
VK_ORCHESTRATOR_PORT=4317
VK_ALLOWED_ORIGINS=http://127.0.0.1:3456,http://localhost:3456
# Local browser-to-orchestrator handshake. `npm run setup` generates this;
# it is not a provider/NocoDB credential and normal users do not manage it.
VK_LOCAL_SECRET=

# Optional overrides. Defaults use the OS user-data directory.
VK_DATA_DIR=
VK_WORKTREE_DIR=
VK_LOG_RETENTION_DAYS=30
VK_AI_REQUEST_TIMEOUT_MS=90000
OPENCODE_BIN=

# Connected-file providers. Tokens are used only by the orchestrator.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:4317/api/connect/google/callback
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_OAUTH_REDIRECT_URI=http://127.0.0.1:4317/api/connect/figma/callback
FIGMA_PERSONAL_ACCESS_TOKEN=

# NocoDB Cloud. The token is server-only and must never use NEXT_PUBLIC_*.
NOCODB_BASE_URL=https://app.nocodb.com
NOCODB_WORKSPACE_ID=wfost257
NOCODB_BASE_ID=pfzvil4cr8t2529
NOCODB_API_TOKEN=

# Browser-facing service location. It contains no credential.
NEXT_PUBLIC_ORCHESTRATOR_URL=http://127.0.0.1:4317
